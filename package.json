{
  "name": "@acovanconis/capacitor-mdns",
  "version": "0.0.3",
  "description": "mDNS plugin for CapacitorJS",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "electron/",
    "ios/Sources",
    "ios/Tests",
    "Package.swift",
    "DevioartsCapacitorMdns.podspec"
  ],
  "author": "Andy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devioarts/capacitor-mdns.git"
  },
  "bugs": {
    "url": "https://github.com/devioarts/capacitor-mdns/issues"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native",
    "multicast-dns",
    "mdns",
    "bonjour",
    "zeroconf",
    "zero-configuration",
    "ios",
    "android",
    "electron"
  ],
  "scripts": {
    "verify": "npm run verify:ios && npm run verify:android && npm run verify:web",
    "verify:ios": "xcodebuild -scheme DevioartsCapacitorMdns -destination generic/platform=iOS",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:web": "npm run build",
    "lint": "npm run eslint && npm run prettier -- --check && npm run swiftlint -- lint",
    "fmt": "npm run eslint -- --fix && npm run prettier -- --write && npm run swiftlint -- --fix --format",
    "eslint": "eslint .",
    "prettier": "prettier \"**/*.{css,html,ts,js,java}\" --plugin=prettier-plugin-java",
    "swiftlint": "node-swiftlint",
    "docgen": "docgen --api mDNSPlugin --output-readme README.md --output-json dist/docs.json",
    "build": "npm run clean && npm run docgen && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "test": "echo \"No test specified\"",
    "prepublishOnly": "npm run build",
    "release": "npm publish --access public"
  },
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/docgen": "^0.3.1",
    "@capacitor/ios": "^8.1.0",
    "@eslint/js": "^9.39.1",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "bonjour-service": "^1.3.0",
    "electron": "41.0.3",
    "eslint": "9.39.4",
    "prettier": "3.8.1",
    "prettier-plugin-java": "2.8.1",
    "rimraf": "6.1.3",
    "rollup": "4.59.0",
    "swiftlint": "^2.0.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@capacitor/core": ">=7.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "prettier": "@ionic/prettier-config",
  "swiftlint": "@ionic/swiftlint-config",
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    },
    "electron": {
      "src": "electron"
    }
  }
}
